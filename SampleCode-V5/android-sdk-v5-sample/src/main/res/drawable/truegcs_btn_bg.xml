<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/truegcs_btn_press" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="@color/truegcs_cyan" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/truegcs_btn_bg" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="@color/truegcs_cyan_transparent" />
        </shape>
    </item>
</selector>
