<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/panel_tactical_bg"
    android:gravity="center_vertical"
    android:elevation="12dp">


    <!-- Initiate Button -->
    <Button
        android:id="@+id/btn_execute_mission"
        android:layout_width="120dp"
        android:layout_height="45dp"
        android:text="INITIATE"
        android:backgroundTint="@color/truegcs_cyan"
        android:textColor="@color/truegcs_bg"
        android:layout_marginEnd="12dp"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Terminate Button -->
    <Button
        android:id="@+id/btn_abort_mission"
        android:layout_width="100dp"
        android:layout_height="40dp"
        android:text="ABORT"
        android:backgroundTint="@color/red_light"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
