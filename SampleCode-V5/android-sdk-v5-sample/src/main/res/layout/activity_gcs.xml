<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/truegcs_bg"
    tools:context="dji.sampleV5.aircraft.DJIGCSActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Main View Container (Full Screen) -->
        <FrameLayout
            android:id="@+id/main_view_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <dji.v5.ux.core.widget.fpv.FPVWidget
                android:id="@+id/widget_primary_fpv"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- PIP View Container (Floating Window) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/pip_view_container"
            android:layout_width="240dp"
            android:layout_height="135dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="100dp"
            app:cardBackgroundColor="@color/black"
            app:cardCornerRadius="8dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <WebView
                android:id="@+id/map_webview"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
            
            <View
                android:id="@+id/pip_click_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true" />
        </androidx.cardview.widget.CardView>

        <!-- Manual Touch Overlay (For Focus square) -->
        <View
            android:id="@+id/touch_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Bottom Command Toolbar (Centered Tactical Strip) -->
        <LinearLayout
            android:id="@+id/bottom_toolbar"
            android:layout_width="wrap_content"
            android:layout_height="65dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/panel_tactical_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:elevation="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Mission Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="12dp">
                <ImageButton
                    android:id="@+id/btn_mission_menu"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/truegcs_btn_bg"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/uxsdk_fpv_hsi_waypoint"
                    app:tint="@color/truegcs_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MISSION"
                    android:textColor="@color/truegcs_cyan"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Takeoff / Land Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="12dp">
                <ImageButton
                    android:id="@+id/btn_takeoff_land"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/truegcs_btn_bg"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/uxsdk_ic_takeoff"
                    app:tint="@color/truegcs_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAKEOFF"
                    android:textColor="@color/truegcs_cyan"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- RTH Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="12dp">
                <ImageButton
                    android:id="@+id/btn_rth"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/truegcs_btn_bg"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/uxsdk_ic_return_home"
                    app:tint="@color/truegcs_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RTH"
                    android:textColor="@color/truegcs_cyan"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Camera Controls Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="12dp">
                <ImageButton
                    android:id="@+id/btn_camera_menu"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/truegcs_btn_bg"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/uxsdk_ic_setting_camera"
                    app:tint="@color/truegcs_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CAMERA"
                    android:textColor="@color/truegcs_cyan"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Mapping Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="12dp">
                <ImageButton
                    android:id="@+id/btn_mapping_menu"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/truegcs_btn_bg"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/uxsdk_ic_topbar_flight_mode"
                    app:tint="@color/truegcs_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAP"
                    android:textColor="@color/truegcs_cyan"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Menu Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btn_main_menu"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/truegcs_btn_bg"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/uxsdk_ic_settings_white_24dp"
                    app:tint="@color/truegcs_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MENU"
                    android:textColor="@color/truegcs_cyan"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Top Status Bar Panel -->
        <dji.v5.ux.core.panel.topbar.TopBarPanelWidget
            android:id="@+id/panel_top_bar"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@color/truegcs_dark_secondary"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:uxsdk_itemsMarginRight="16dp"
            app:uxsdk_itemsSpacing="12dp" />

        <!-- Flight Time Progress Bar -->
        <dji.v5.ux.core.widget.remainingflighttime.RemainingFlightTimeWidget
            android:id="@+id/widget_remaining_flight_time"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            app:layout_constraintTop_toBottomOf="@+id/panel_top_bar" />

        <!-- Camera Quick Config (Functional Sliders) -->
        <dji.v5.ux.visualcamera.CameraVisiblePanelWidget
            android:id="@+id/widget_camera_config"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_marginTop="8dp"
            android:background="@color/truegcs_dark_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/widget_remaining_flight_time" />

        <!-- Left Side Telemetry Dashboard -->
        <LinearLayout
            android:id="@+id/left_dashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@color/truegcs_dark_transparent"
            android:orientation="vertical"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALTITUDE"
                android:textColor="@color/truegcs_cyan"
                android:textSize="10sp"
                android:textStyle="bold" />
            <dji.v5.ux.core.widget.altitude.AGLAltitudeWidget
                android:id="@+id/widget_altitude"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Space android:layout_width="1dp" android:layout_height="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISTANCE"
                android:textColor="@color/truegcs_cyan"
                android:textSize="10sp"
                android:textStyle="bold" />
            <dji.v5.ux.core.widget.distancehome.DistanceHomeWidget
                android:id="@+id/widget_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Space android:layout_width="1dp" android:layout_height="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPEED"
                android:textColor="@color/truegcs_cyan"
                android:textSize="10sp"
                android:textStyle="bold" />
            <dji.v5.ux.core.widget.horizontalvelocity.HorizontalVelocityWidget
                android:id="@+id/widget_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>


        <!-- Right Side Main Camera Controls -->
        <dji.v5.ux.cameracore.widget.cameracontrols.CameraControlsWidget
            android:id="@+id/widget_camera_controls"
            android:layout_width="wrap_content"
            android:layout_height="220dp"
            android:layout_marginEnd="80dp"
            android:background="@android:color/transparent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- System Message Overlay -->
        <dji.v5.ux.core.widget.systemstatus.SystemStatusWidget
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/widget_camera_config" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RIGHT DRAWER: Comprehensive Aircraft Settings -->
    <LinearLayout
        android:id="@+id/camera_settings_drawer_container"
        android:layout_width="590dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:background="@color/truegcs_dark_secondary">

        <dji.v5.ux.core.widget.setting.SettingPanelWidget
            android:id="@+id/camera_settings_drawer"
            android:layout_width="510dp"
            android:layout_height="match_parent" />

        <View
            android:layout_width="80dp"
            android:layout_height="match_parent" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
