<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/truegcs_bg"
    tools:context="dji.sampleV5.aircraft.DJIGCSActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Main View Container (Full Screen) -->
        <FrameLayout
            android:id="@+id/main_view_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <dji.v5.ux.core.widget.fpv.FPVWidget
                android:id="@+id/widget_primary_fpv"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- PIP View Container (Floating Window) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/pip_view_container"
            android:layout_width="240dp"
            android:layout_height="135dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="100dp"
            app:cardBackgroundColor="@color/black"
            app:cardCornerRadius="8dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <WebView
                android:id="@+id/map_webview"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
            
            <View
                android:id="@+id/pip_click_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true" />
        </androidx.cardview.widget.CardView>

        <!-- Manual Touch Overlay (For Focus square) -->
        <View
            android:id="@+id/touch_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Left Command Sidebar -->
        <LinearLayout
            android:id="@+id/left_sidebar"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:layout_marginTop="50dp"
            android:background="@color/truegcs_dark_transparent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:elevation="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_mission_menu"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/truegcs_btn_bg"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/uxsdk_fpv_hsi_waypoint"
                app:tint="@color/truegcs_cyan" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MISSION"
                android:textColor="@color/truegcs_cyan"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Top Status Bar Panel -->
        <dji.v5.ux.core.panel.topbar.TopBarPanelWidget
            android:id="@+id/panel_top_bar"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@color/truegcs_dark_secondary"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:uxsdk_itemsMarginRight="16dp"
            app:uxsdk_itemsSpacing="12dp" />

        <!-- Flight Time Progress Bar -->
        <dji.v5.ux.core.widget.remainingflighttime.RemainingFlightTimeWidget
            android:id="@+id/widget_remaining_flight_time"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            app:layout_constraintTop_toBottomOf="@+id/panel_top_bar" />

        <!-- Camera Quick Config (Functional Sliders) -->
        <dji.v5.ux.visualcamera.CameraVisiblePanelWidget
            android:id="@+id/widget_camera_config"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_marginTop="8dp"
            android:background="@color/truegcs_dark_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/widget_remaining_flight_time" />

        <!-- Left Side Telemetry Dashboard -->
        <LinearLayout
            android:id="@+id/left_dashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@color/truegcs_dark_transparent"
            android:orientation="vertical"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALTITUDE"
                android:textColor="@color/truegcs_cyan"
                android:textSize="10sp"
                android:textStyle="bold" />
            <dji.v5.ux.core.widget.altitude.AGLAltitudeWidget
                android:id="@+id/widget_altitude"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Space android:layout_width="1dp" android:layout_height="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISTANCE"
                android:textColor="@color/truegcs_cyan"
                android:textSize="10sp"
                android:textStyle="bold" />
            <dji.v5.ux.core.widget.distancehome.DistanceHomeWidget
                android:id="@+id/widget_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Space android:layout_width="1dp" android:layout_height="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPEED"
                android:textColor="@color/truegcs_cyan"
                android:textSize="10sp"
                android:textStyle="bold" />
            <dji.v5.ux.core.widget.horizontalvelocity.HorizontalVelocityWidget
                android:id="@+id/widget_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Minimalist Compass Arrow -->
        <FrameLayout
            android:id="@+id/compass_container"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <dji.v5.ux.core.widget.compass.CompassWidget
                android:id="@+id/widget_compass"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- Flight Action Controls -->
        <LinearLayout
            android:id="@+id/flight_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <dji.v5.ux.flight.takeoff.TakeOffWidget
                android:id="@+id/widget_takeoff"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginEnd="32dp" />

            <dji.v5.ux.flight.returnhome.ReturnHomeWidget
                android:id="@+id/widget_rth"
                android:layout_width="50dp"
                android:layout_height="50dp" />
        </LinearLayout>

        <!-- Right Side Main Camera Controls -->
        <dji.v5.ux.cameracore.widget.cameracontrols.CameraControlsWidget
            android:id="@+id/widget_camera_controls"
            android:layout_width="wrap_content"
            android:layout_height="220dp"
            android:layout_marginEnd="80dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Toggle Button for Deep Settings -->
        <Button
            android:id="@+id/btn_toggle_camera"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:background="@color/truegcs_cyan"
            android:text="MENU"
            android:textColor="@color/truegcs_bg"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/widget_camera_controls"
            app:layout_constraintTop_toBottomOf="@+id/widget_camera_controls" />

        <!-- System Message Overlay -->
        <dji.v5.ux.core.widget.systemstatus.SystemStatusWidget
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/widget_camera_config" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RIGHT DRAWER: Comprehensive Aircraft Settings -->
    <LinearLayout
        android:id="@+id/camera_settings_drawer_container"
        android:layout_width="590dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:background="@color/truegcs_dark_secondary">

        <dji.v5.ux.core.widget.setting.SettingPanelWidget
            android:id="@+id/camera_settings_drawer"
            android:layout_width="510dp"
            android:layout_height="match_parent" />

        <View
            android:layout_width="80dp"
            android:layout_height="match_parent" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
