<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/truegcs_dialog_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2D PHOTOGRAMMETRY"
            android:textColor="@color/truegcs_cyan"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nadir Mapping Grid (Mini 3 / 4:3)"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <!-- ALTITUDE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALTITUDE (M)"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/edit_mapping_alt"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/truegcs_btn_bg"
            android:inputType="numberDecimal"
            android:text="50"
            android:textColor="@color/truegcs_cyan"
            android:padding="8dp"
            android:textSize="14sp"
            android:layout_marginBottom="10dp" />

        <!-- SPEED -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GROUND SPEED (M/S)"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/edit_mapping_speed"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/truegcs_btn_bg"
            android:inputType="numberDecimal"
            android:text="5"
            android:textColor="@color/truegcs_cyan"
            android:padding="8dp"
            android:textSize="14sp"
            android:layout_marginBottom="10dp" />

        <!-- ESTIMATES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2200FFFF"
            android:padding="8dp"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:id="@+id/txt_mapping_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forward Spacing: 16.0m\nLane Spacing: 21.0m\nOverlap: 70%"
                android:textColor="@color/truegcs_cyan"
                android:textSize="10sp" />
        </LinearLayout>

        <ToggleButton
            android:id="@+id/toggle_draw_area"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:textOn="DRAW MODE: ON"
            android:textOff="DRAW MODE: OFF"
            android:textColor="@color/white"
            android:background="@drawable/truegcs_btn_bg"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_clear_map"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="CLEAR MAP"
            android:textColor="@color/truegcs_cyan"
            android:backgroundTint="#112222"
            android:background="@drawable/truegcs_btn_bg"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_prep_gimbal"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="PREP GIMBAL (-90°)"
            android:textColor="@color/truegcs_cyan"
            android:backgroundTint="#112222"
            android:background="@drawable/truegcs_btn_bg"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_generate_grid"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="GENERATE GRID"
            android:textColor="#000000"
            android:backgroundTint="@color/truegcs_cyan"
            android:textStyle="bold"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
